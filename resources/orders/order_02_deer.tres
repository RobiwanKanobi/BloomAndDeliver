[gd_resource type="Resource" script_class="OrderData" load_steps=4 format=3]

[ext_resource type="Script" path="res://scripts/data/OrderData.gd" id="1"]
[ext_resource type="Script" path="res://scripts/data/OrderRequirementData.gd" id="2"]

[sub_resource type="Resource" id="req1"]
script = ExtResource("2")
